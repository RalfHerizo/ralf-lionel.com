{
  "version": 2,
  "buildCommand": "npm install",
  "public": ".",
  "functions": {
    "api/**/*.js": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "GMAIL_USER": "@gmail_user",
    "GMAIL_PASSWORD": "@gmail_app_password",
    "RECIPIENT_EMAIL": "@recipient_email"
  }
}
